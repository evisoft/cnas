@using Cnas.Ps.Contracts
@inject IClassifierLookup Lookup

@*
    R0403 / CF 17.08 — single-select classifier dropdown. Loads rows from the
    injected IClassifierLookup (active-only invariant guaranteed at the
    service layer) and emits OnValueChanged when the user picks an option.
    The empty-state container renders when the lookup returns zero rows so
    the caller does not have to special-case the "scheme has no active codes"
    branch in their own markup.
*@

@if (_rows.Count == 0)
{
    <span class="classifier-empty" data-testid="classifier-empty">—</span>
}
else
{
    <select class="classifier-select"
            data-testid="classifier-select"
            disabled="@Disabled"
            required="@Required"
            value="@Value"
            @onchange="OnChangeAsync">
        <option value="">—</option>
        @foreach (var row in _rows)
        {
            <option value="@row.Code"
                    data-testid="classifier-option">@row.Code — @row.LabelRo</option>
        }
    </select>
}

@code {
    /// <summary>Classifier scheme code to load (e.g. <c>CAEM</c>, <c>CUATM</c>, <c>CFOJ</c>).</summary>
    [Parameter, EditorRequired] public string SchemeCode { get; set; } = string.Empty;

    /// <summary>Currently-selected code (two-way binding via <see cref="OnValueChanged"/>).</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Callback invoked when the user picks a different option.</summary>
    [Parameter] public EventCallback<string?> OnValueChanged { get; set; }

    /// <summary>When <c>true</c>, the dropdown is rendered in the disabled state.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>When <c>true</c>, the dropdown is required for form submission.</summary>
    [Parameter] public bool Required { get; set; }

    /// <summary>The active rows fetched from the lookup; never <c>null</c>.</summary>
    private IReadOnlyList<ClassifierRow> _rows = Array.Empty<ClassifierRow>();

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(SchemeCode))
        {
            _rows = Array.Empty<ClassifierRow>();
            return;
        }

        _rows = await Lookup.GetActiveAsync(SchemeCode).ConfigureAwait(false);
    }

    /// <summary>
    /// Forwards the selected code (empty string normalised to <c>null</c>) to
    /// the consumer's <see cref="OnValueChanged"/> callback.
    /// </summary>
    /// <param name="e">The change event surfaced by the &lt;select&gt; element.</param>
    /// <returns>Async task.</returns>
    private async Task OnChangeAsync(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        var normalised = string.IsNullOrEmpty(raw) ? null : raw;
        Value = normalised;
        if (OnValueChanged.HasDelegate)
        {
            await OnValueChanged.InvokeAsync(normalised).ConfigureAwait(false);
        }
    }
}
