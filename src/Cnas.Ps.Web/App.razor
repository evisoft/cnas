@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing

@*
    Root router for the citizen portal. The router is wrapped in a
    CascadingAuthenticationState so descendant pages + AuthorizeView blocks
    receive the current AuthenticationState produced by
    CookieAuthStateProvider. The AuthorizeRouteView enforces any [Authorize]
    attribute on a matched page — without this, the attributes would be
    silently inert (the page would render even for anonymous callers).
*@
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <p>Acces refuzat. <a href="/">Înapoi la pagina principală</a></p>
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <p>Pagina nu a fost găsită.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
