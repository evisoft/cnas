@page "/registers/payment-orders"
@using Microsoft.AspNetCore.Authorization
@using Cnas.Ps.Contracts
@using Cnas.Ps.Web.Backend
@attribute [Authorize]
@inject CnasApiClient Api

@*
    R1602 + R1604 / TOR Annex 3.10 — read-only browser for the
    RegistrulConturilorDePlata projection.

    Authorisation is enforced server-side; the page surfaces transport
    failures as an inline error rather than crashing.

    Per SEC 035 the IBAN column renders ONLY the masked form provided by the
    backend — the page never receives the plaintext.
*@

<PageTitle>Registrul comenzilor de plată (R1602)</PageTitle>

<header class="page-header">
    <h1 data-testid="payment-orders-register-heading">Registrul comenzilor de plată</h1>
    <p class="hint">
        TOR Annex 3.10 — conturile de plată per beneficiar proiectate din MPayOrder.
    </p>
</header>

@if (_error is not null)
{
    <div class="alert alert-error" role="alert" data-testid="payment-orders-register-error">
        <strong>Eroare</strong> <code>@_error</code>
    </div>
}

<form class="filters" data-testid="payment-orders-register-filters" @onsubmit="ReloadAsync" @onsubmit:preventDefault>
    <label>
        IDNP beneficiar:
        <input type="text" data-testid="payment-orders-filter-idnp" @bind="_idnp" placeholder="13 cifre" />
    </label>
    <button type="submit" data-testid="payment-orders-register-search">Caută</button>
</form>

<section class="exports" data-testid="payment-orders-register-exports">
    @* iter-113 export pipeline wire-up is pending — buttons are disabled until the
       persistence endpoint lands. Keep the buttons in the DOM (with a tooltip + the
       disabled attribute) so the accessibility tree and keyboard-navigation tests
       continue to find their target without invoking the no-op handler. *@
    <button type="button" data-testid="payment-orders-export-csv" disabled title="Export is not yet available">Export CSV</button>
    <button type="button" data-testid="payment-orders-export-xlsx" disabled title="Export is not yet available">Export XLSX</button>
    <button type="button" data-testid="payment-orders-export-pdf" disabled title="Export is not yet available">Export PDF</button>
</section>

@if (_rows is null && _error is null)
{
    <p data-testid="payment-orders-register-loading">Se încarcă...</p>
}
else if (_rows is { Items: var items } && items.Count == 0)
{
    <p data-testid="payment-orders-register-empty">Niciun cont în rezultate.</p>
}
else if (_rows is not null)
{
    <table class="register-table" data-testid="payment-orders-register-table">
        <thead>
            <tr>
                <th>IBAN (mascat)</th>
                <th>Metodă plată</th>
                <th>Stare</th>
                <th>Ultima plată (UTC)</th>
                <th>Total YTD (MDL)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _rows.Items)
            {
                <tr data-testid="payment-orders-register-row">
                    <td>@row.Iban</td>
                    <td>@row.PaymentMethod</td>
                    <td>@row.Status</td>
                    <td>@(row.LastPaymentAtUtc?.ToString("u") ?? "—")</td>
                    <td>@row.TotalPaidYtd.ToString("0.00")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    /// <summary>Optional raw IDNP filter applied to the listing.</summary>
    private string? _idnp;

    /// <summary>Cached paged result; null until first load completes.</summary>
    private PagedResult<BeneficiaryPaymentAccountRowDto>? _rows;

    /// <summary>Last transport-error message, or null on the happy path.</summary>
    private string? _error;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync().ConfigureAwait(false);
    }

    /// <summary>Reloads the table using the current filter state.</summary>
    private async Task ReloadAsync()
    {
        _error = null;
        var result = await Api.ListPaymentAccountsRegisterAsync(_idnp).ConfigureAwait(false);
        if (result.IsFailure)
        {
            _error = result.ErrorMessage;
            return;
        }
        _rows = result.Value;
    }

    // Export pipeline wire-up is pending — the buttons are rendered with the
    // `disabled` attribute so the no-op click handler is no longer reachable.
}
