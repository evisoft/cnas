{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithEnvironmentName", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "Postgres": "",
    "PostgresReadReplica": ""
  },
  "Sqids": {
    "Alphabet": "FedcbHijklmnoGpqrstuvwxyZ0123456789ABCDEIJKLMNOPQRSTUVWXY",
    "MinLength": 8
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "",
    "SecretKey": "",
    "UseSsl": false,
    "CitizenUploadsBucket": "cnas-citizen-uploads",
    "GeneratedDocumentsBucket": "cnas-generated",
    "MaxFileSizeBytes": 26214400
  },
  "MGov": {
    "MPassIssuer": "",
    "MPassClientId": "",
    "MPassClientSecret": "",
    "MSignBaseUrl": "",
    "MPayBaseUrl": "",
    "MConnectBaseUrl": "",
    "MNotifyBaseUrl": "",
    "MLogBaseUrl": ""
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:8081" ]
  },
  "AllowedHosts": "*"
}
