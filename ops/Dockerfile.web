# syntax=docker/dockerfile:1.7
#
# Multi-stage Dockerfile for Cnas.Ps.Web — Blazor WebAssembly Standalone.
# The build stage publishes the WASM bundle; the runtime stage serves it as static
# files via Nginx. The browser then calls the Api host strictly over HTTP/REST.
#

# -----------------------------------------------------------------------------
# Build stage
# -----------------------------------------------------------------------------
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /src

# Cache restore by copying just project metadata first.
COPY Directory.Build.props Directory.Packages.props ./
COPY Cnas.Ps.slnx ./
COPY src/Cnas.Ps.Core/Cnas.Ps.Core.csproj                   src/Cnas.Ps.Core/
COPY src/Cnas.Ps.Contracts/Cnas.Ps.Contracts.csproj         src/Cnas.Ps.Contracts/
COPY src/Cnas.Ps.Web/Cnas.Ps.Web.csproj                     src/Cnas.Ps.Web/

# BlazorCN sibling repository must be available at ../blazorcn relative to the build
# context. The docker compose build context covers both repositories.
COPY ../blazorcn/src/BlazorCN/BlazorCN.csproj ../blazorcn/src/BlazorCN/

RUN dotnet restore src/Cnas.Ps.Web/Cnas.Ps.Web.csproj

COPY . ./
COPY ../blazorcn ../blazorcn

RUN dotnet publish src/Cnas.Ps.Web/Cnas.Ps.Web.csproj \
        --configuration Release \
        --output /app/publish \
        --no-restore \
        -p:GenerateDocumentationFile=false \
        -p:TreatWarningsAsErrors=false

# -----------------------------------------------------------------------------
# Runtime stage — Nginx serving the WASM bundle
# -----------------------------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Pre-baked nginx config tuned for Blazor WASM: long cache for hashed assets,
# no-store for index.html + appsettings, Brotli/Gzip fallback, SPA fallback to /.
COPY ops/nginx-blazor.conf /etc/nginx/conf.d/default.conf

# The published WASM bundle is at /app/publish/wwwroot.
COPY --from=build /app/publish/wwwroot/ /usr/share/nginx/html/

# Drop privileges — nginx itself runs as the unprivileged `nginx` user once we
# bind to a non-privileged port.
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=5 \
    CMD wget -qO- http://127.0.0.1:8080/ >/dev/null || exit 1

CMD ["nginx", "-g", "daemon off;"]
